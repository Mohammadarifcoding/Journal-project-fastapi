// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-py"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String?
  createdAt    DateTime @default(now())
  password     String
  refreshToken String?
  logs         Log[]

  noteFiles NoteFile[]
}

model Log {
  id         String      @id @default(uuid())
  userId     String
  title      String
  content    String
  tags       String[]
  createdAt  DateTime    @default(now())
  user       User        @relation(fields: [userId], references: [id])
  aiAnalyses AiAnalysis?
}

model AiAnalysis {
  id                  String    @id @default(uuid())
  logId               String    @unique
  summary             String?
  key_points          String[]  @default([])
  suggested_tags      String[]  @default([])
  status              String    @default("queued")
  learning_score      Int?
  retryCount          Int       @default(0)
  lastError           String?
  processingStartedAt DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  log                 Log       @relation(fields: [logId], references: [id], onDelete: Cascade)
}

model NoteFile {
  id        String   @id @default(uuid())
  userId    String
  filename  String
  filepath  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
